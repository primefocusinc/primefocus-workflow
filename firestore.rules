rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }

    function isAdminOrDoctor() {
      return isAdmin() || isDoctor();
    }

    match /users/{userId} {
      // New users can create their own profile with the default role only.
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'basic-user';

      // Users can read their own profile; admins can read any profile.
      allow read: if isAuthenticated()
                   && (request.auth.uid == userId || isAdmin());

      // Users can update their own profile but cannot change their role.
      // Admins can update any profile, including roles.
      allow update: if isAuthenticated()
                     && (
                       (request.auth.uid == userId
                        && (!('role' in request.resource.data)
                            || request.resource.data.role == resource.data.role))
                       || isAdmin()
                     );

      // Only admins can delete user profiles.
      allow delete: if isAdmin();
    }

    match /participants/{participantId} {
      // Anyone (authenticated or anonymous) can create a participant record during registration.
      allow create: if true;

      // Public registration uses setDoc(..., { merge: true }) keyed by email.
      // Returning participants therefore perform updates, not just creates.
      allow update: if true;

      // Only admins and doctors can read participant records.
      allow read: if isAdminOrDoctor();

      // Only admins and doctors can delete participant records.
      allow delete: if isAdminOrDoctor();
    }

    match /events/{eventId} {
      // Anyone can create the initial event record during public registration.
      allow create: if true;

      // Only admins and doctors can read, update, or delete event records.
      allow read, update, delete: if isAdminOrDoctor();
    }

    match /registrationEvents/{eventId} {
      // Registration pages need to read available events, but only admins can manage them.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stationStatuses/{statusId} {
      // Anyone can create the initial station statuses during public registration.
      allow create: if true;

      // Only admins and doctors can read, update, or delete station status records.
      allow read, update, delete: if isAdminOrDoctor();
    }
  }
}
